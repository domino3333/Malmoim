<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.malmoim.mapper.QnaRoomMapper">


    <insert id="createQnaRoom">
        insert into qna_room(room_no,question_started_at,question_ended_at) values(#{roomNo},null,null)
    </insert>

    <update id="updateQuestionStartedAt">
        update qna_room set question_started_at=#{startedAt},question_ended_at=#{endedAt}  where room_no =#{roomNo}
    </update>


    <select id="selectStEndedAtOfTheRoom">
        select * from qna_room where room_no =#{roomNo}
    </select>
</mapper>