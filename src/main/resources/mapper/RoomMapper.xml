<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.malmoim.mapper.RoomMapper">


    <insert id="CreateQnARoom">
        insert into room(host_no,title,code,capacity,password,status,type)
        values(#{hostNo},#{title},#{code},#{capacity},#{password},#{status},#{type})
    </insert>

    <select id="getMyRooms">
        select * from room where host_no =#{no} order by create_at desc
        limit #{size} offset #{page}

    </select>

</mapper>