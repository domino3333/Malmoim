<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.malmoim.mapper.RoomMapper">


    <!-- room 테이블에 방 추가. -->
    <insert id="insertRoom" useGeneratedKeys="true" keyProperty="no">
        insert into room(host_no,title,code,capacity,password,visibility,type)
        values(#{hostNo},#{title},#{code},#{capacity},#{password},#{visibility},#{type})
    </insert>

    <select id="getMyRooms" resultType="Room">
        select * from room where host_no =#{no} order by created_at desc
        limit #{size} offset #{offset}

    </select>

    <select id="countMyRooms" resultType="integer">
        select count(*) from room where host_no =#{no}
    </select>

    <!-- 방 번호와 호스트 번호가 일치하는 방 조회. -->
    <select id="selectRoomByNoAndHostNo" resultType="Room">
        select * from room where no=#{no} and host_no=#{hostNo}
    </select>

    <update id="updateRoomStatus">
        update room set status=#{status} where no = #{roomNo} and host_no =#{hostNo}
    </update>

    <!-- 동일한 입장 코드를 가진 방 개수 조회. -->
    <select id="countRoomsByCode" resultType="integer">
        select COUNT(*) from room where code = #{code}
    </select>

    <!-- 방 번호 기준 단일 방 조회. -->
    <select id="selectRoomByNo" resultType="Room">
        select * from room where no =#{no}
    </select>

</mapper>
